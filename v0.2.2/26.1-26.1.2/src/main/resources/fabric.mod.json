    "client": [
      "com.secondmod.autotunefps.client.AutoTuneFpsClient"
    ]
  },
  "mixins": [
    "autotune_fps.client.mixins.json"
  ],
  "depends": {
    "fabricloader": ">=0.19.2",
    "minecraft": ">=26.1 <=26.1.2",
